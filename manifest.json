{
  "manifest_version": 3,
  "name": "Skeleton API",
  "version": "1.0",
  "description": "Deep JSON to TypeScript & Fetch Generator",
  "permissions": ["sidePanel", "activeTab", "scripting", "clipboardWrite", "tabs"],
  "action": {
    "default_title": "Open Skeleton API"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "host_permissions": ["<all_urls>"]
}